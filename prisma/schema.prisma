generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["faculty_schema"]
}

// ================= ENUMS (faculty_schema) =================

enum AppRole {
  ADMIN
  STAFF
  STUDENT
  SCHEDULER

  @@schema("faculty_schema")
}

enum RequestType {
  SWAP
  RESCHEDULE
  LEAVE

  @@schema("faculty_schema")
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN

  @@schema("faculty_schema")
}

enum NotificationType {
  REQUEST_UPDATE
  SCHEDULE_CHANGE
  ANNOUNCEMENT
  REMINDER
  SYSTEM

  @@schema("faculty_schema")
}

enum ScheduleItemType {
  LECTURE
  LAB
  TUTORIAL
  SEMINAR
  OFFICE_HOURS

  @@schema("faculty_schema")
}

enum PreferredSlot {
  MORNING
  AFTERNOON
  EVENING
  ANY

  @@schema("faculty_schema")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY

  @@schema("faculty_schema")
}

enum FacultyStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE

  @@schema("faculty_schema")
}

enum AssignmentStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED

  @@schema("faculty_schema")
}

// ================= AUTH TABLES (faculty_schema) =================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  role          AppRole  @default(STAFF)

  sessions Session[]
  accounts Account[]
  faculty  Faculty?

  @@schema("faculty_schema")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@schema("faculty_schema")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("faculty_schema")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@schema("faculty_schema")
}

// ================= FACULTY TABLES (faculty_schema) =================

model Faculty {
  id           String        @id @default(uuid())
  userId       String        @unique
  departmentId Int?
  employeeId   String        @unique
  designation  String
  joiningDate  DateTime      @default(now())
  status       FacultyStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile           FacultyProfile?
  schedules         FacultySchedule[]
  availability      FacultyAvailability?
  requests          FacultyRequest[]
  notifications     FacultyNotification[]
  preferredSubjects FacultyPreferredSubject[]
  teachingHistory   FacultyTeachingHistory[]

  @@index([departmentId])
  @@index([status])
  @@schema("faculty_schema")
}

model FacultyPreferredSubject {
  id          String   @id @default(uuid())
  facultyId   String
  subjectName String
  createdAt   DateTime @default(now())

  faculty Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@unique([facultyId, subjectName])
  @@index([facultyId])
  @@schema("faculty_schema")
}

/// Teaching experience outside or before our scheduling system (other institutions,
/// manual CV-style entries). Not the same as `FacultySchedule` (internal assignments).
model FacultyTeachingHistory {
  id              String    @id @default(uuid())
  facultyId       String
  institutionName String
  courseTitle     String
  subjectArea     String?
  termLabel       String?
  academicYear    String?
  startDate       DateTime?
  endDate         DateTime?
  studentCount    Int?
  notes           String?
  isExternal      Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  faculty Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@index([facultyId])
  @@index([institutionName])
  @@index([courseTitle])
  @@schema("faculty_schema")
}

model FacultyProfile {
  id                String   @id
  facultyId         String   @unique
  bio               String?
  phone             String?
  officeLocation    String?
  officeHours       String?
  researchInterests String[] @default([])
  qualifications    String[] @default([])
  publications      String[] @default([])
  socialLinks       Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  Faculty           Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
}

  faculty Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@schema("faculty_schema")
}

model FacultySchedule {
  id               String           @id @default(uuid())
  facultyId        String
  courseId         Int?
  roomId           Int?
  termId           Int?
  dayOfWeek        DayOfWeek
  startTime        String
  endTime          String
  type             ScheduleItemType @default(LECTURE)
  section          String?
  program          String?
  /// Legacy labeling; prefer `termId` as source of truth when present.
  semester         Int?
  academicYear     String?
  isActive         Boolean          @default(true)
  assignmentStatus AssignmentStatus @default(ACTIVE)
  studentCount     Int?
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  faculty Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  @@index([facultyId])
  @@index([facultyId, dayOfWeek])
  @@index([facultyId, isActive])
  @@index([termId])
  @@index([assignmentStatus])
  @@index([courseId])
  @@index([roomId])
  @@schema("faculty_schema")
}

model FacultyAvailability {
  id               String        @id @default(uuid())
  facultyId        String        @unique
  preferredSlot    PreferredSlot @default(ANY)
  customStartTime  String?
  customEndTime    String?
  unavailableStart String?
  unavailableEnd   String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  faculty Faculty                  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  days    FacultyAvailabilityDay[]

  @@schema("faculty_schema")
}

model FacultyAvailabilityDay {
  id             String    @id @default(uuid())
  availabilityId String
  dayOfWeek      DayOfWeek
  isAvailable    Boolean   @default(true)
  /// When `isAvailable` is true, writers should set both times (app-level validation).
  startTime      String?
  endTime        String?

  @@index([token])
  @@index([userId])
}

  @@unique([availabilityId, dayOfWeek])
  @@index([availabilityId])
  @@schema("faculty_schema")
}

model FacultyRequest {
  id               String        @id @default(uuid())
  facultyId        String
  type             RequestType
  status           RequestStatus @default(PENDING)
  title            String
  description      String?
  requestDate      DateTime      @default(now())
  effectiveDate    DateTime
  endDate          DateTime?
  targetFacultyId  String?
  targetScheduleId String?
  newDate          DateTime?
  newStartTime     String?
  newEndTime       String?
  reason           String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  faculty  Faculty                  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  timeline FacultyRequestTimeline[]

  @@index([facultyId, status])
  @@index([facultyId, createdAt(sort: Desc)])
  @@schema("faculty_schema")
}

model FacultyRequestTimeline {
  id        String        @id @default(uuid())
  requestId String
  status    RequestStatus
  comment   String?
  createdBy String
  createdAt DateTime      @default(now())

enum NotificationType {
  REQUEST_UPDATE
  SCHEDULE_CHANGE
  ANNOUNCEMENT
  REMINDER
  SYSTEM
}

  @@index([requestId])
  @@schema("faculty_schema")
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum RequestType {
  SWAP
  RESCHEDULE
  LEAVE
}

  @@index([facultyId, isRead])
  @@index([facultyId, createdAt(sort: Desc)])
  @@schema("faculty_schema")
}
